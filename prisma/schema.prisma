// LeetCode Tracker — Prisma schema
// Multi-user, per-user sheets, denormalized questions per sheet.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  hashedPassword String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sheets          Sheet[]
  solvedQuestions SolvedQuestion[]
}

model Sheet {
  id        String     @id @default(cuid())
  ownerId   String
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  questions Question[]

  @@unique([ownerId, name])
  @@index([ownerId])
}

model Question {
  id           String   @id @default(cuid())
  sheetId      String
  ownerId      String
  leetcodeId   Int
  url          String
  title        String
  difficulty   String   // "Easy" | "Medium" | "Hard"  (also called "level")
  difficultyOrder Int   // 0=Easy, 1=Medium, 2=Hard (for sorting)
  primaryTopic String   @default("Uncategorized")  // e.g. "Dynamic Programming", "Arrays"
  solved       Boolean  @default(false)
  solvedAt     DateTime?
  createdAt    DateTime @default(now())

  sheet        Sheet    @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@unique([sheetId, leetcodeId])
  @@index([sheetId, difficulty])
  @@index([sheetId, primaryTopic])
  @@index([sheetId, solved])
  @@index([ownerId])
  @@index([ownerId, leetcodeId])
}

// Global solved state per (user, leetcodeId). When a user marks a question as
// solved in any sheet, this is upserted. All Question rows for the same
// (ownerId, leetcodeId) are kept in sync — so solving in one sheet marks it
// solved in every sheet that contains that leetcode_id.
model SolvedQuestion {
  id          String   @id @default(cuid())
  ownerId     String
  leetcodeId  Int
  solvedAt    DateTime @default(now())

  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, leetcodeId])
  @@index([ownerId])
}
